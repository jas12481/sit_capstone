# Copy this file to .env.local and fill in your values

# MCP Server — used server-side by Next.js rewrites
MCP_BASE_URL=http://localhost:8000

# MCP Server — used client-side (shown in sidebar footer)
NEXT_PUBLIC_MCP_URL=http://localhost:8000

# Dify orchestrator — get from Dify > your app > API Access
# Server-only (no NEXT_PUBLIC_ prefix): read by app/api/dify/chat/route.ts,
# never sent to the browser. The Chat page calls that route, not Dify directly.
DIFY_URL=https://api.dify.ai
DIFY_API_KEY=app-xxxxxxxxxxxxxxxxxxxxxxxx

# GitHub repo for commit links in DSL view (e.g. jazzhands/sit_capstone)
NEXT_PUBLIC_GITHUB_REPO=your-username/sit_capstone
